ANTHROPIC_API_KEY=sk-ant-...
DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/strouv
VERIFY_TOKEN=un-string-secreto-que-tu-eliges
# Los tokens de WhatsApp van POR TENANT en la tabla tenants (wa_token, wa_phone_id),
# no aquí: cada negocio conecta su propio número.
MODEL_BRAIN=claude-fable-5
MODEL_CHEAP=claude-haiku-4-5
DEBOUNCE_SECONDS=4
HISTORY_WINDOW=20
